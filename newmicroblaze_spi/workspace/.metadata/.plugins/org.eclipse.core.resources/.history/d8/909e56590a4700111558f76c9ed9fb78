#include "interrupt.h"

volatile uint8_t spi_tx_flag = 0;
volatile uint8_t spi_rx_data = 0;
XIntc IntrController;

void DUMMY_ISR(void *CallbackRef) { }

void TMR1_ISR(void *CallbackRef) {
    static int debug_cnt = 0;
    if (debug_cnt++ % 1000 == 0) xil_printf("*"); // 1УЪПЁ Чб ЙјОП ХЭЙЬГЮПЁ '*' УтЗТ
    millis_inc();
    UpCounter_DisLoop();
}

void TMR2_ISR(void *CallbackRef)
{
    spi_tx_flag = 1;
}


int SetupInterruptSystem()
{
    int status;

    status = XIntc_Initialize(&IntrController, INTC_DEV_ID);
    if (status != XST_SUCCESS) return XST_FAILURE;

    XIntc_Connect(&IntrController, XPAR_INTC_0_TMR_0_VEC_ID, (XInterruptHandler)DUMMY_ISR, (void *)0);
    XIntc_Connect(&IntrController, XPAR_INTC_0_TMR_1_VEC_ID, (XInterruptHandler)TMR1_ISR, (void *)0);
    XIntc_Connect(&IntrController, XPAR_INTC_0_TMR_2_VEC_ID, (XInterruptHandler)TMR2_ISR, (void *)0);

    // Master EnableИИ ЧЯДТ ДыНХ StartИІ ЛчПы (REAL_MODE)
    status = XIntc_Start(&IntrController, XIN_REAL_MODE);
    if (status != XST_SUCCESS) return XST_FAILURE;

    XIntc_Enable(&IntrController, XPAR_INTC_0_TMR_1_VEC_ID);
    XIntc_Enable(&IntrController, XPAR_INTC_0_TMR_2_VEC_ID);

    Xil_ExceptionInit();
    Xil_ExceptionRegisterHandler(XIL_EXCEPTION_ID_INT,
            (Xil_ExceptionHandler)XIntc_InterruptHandler,
            &IntrController);
    Xil_ExceptionEnable();

    return XST_SUCCESS;
}
