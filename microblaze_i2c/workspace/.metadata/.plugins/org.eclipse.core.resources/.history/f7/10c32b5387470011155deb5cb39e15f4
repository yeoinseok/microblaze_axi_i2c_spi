#include "UpCounter.h"

hBtn_t hBtnRunStop, hBtnClear;
uint16_t counter = 0;
uint16_t slave_val = 0;

void UpCounter_Init(){
    I2C_Init(I2C0, 49, 0x12);  // clk_div=49, slave_addr=0x12
    FND_Init();
    GPIO_SetMode(GPIOC, GPIO_PIN_0, INPUT);  // sw[15] = R/W 모드
    Button_Init(&hBtnRunStop, GPIOA, GPIO_PIN_4);
    Button_Init(&hBtnClear, GPIOA, GPIO_PIN_7);
    counter = 0;
    slave_val = 0;
}

void UpCounter_Excute(){
    uint8_t rw_mode = GPIO_ReadPin(GPIOC, GPIO_PIN_0); // 0=write, 1=read

    static uint32_t prevI2cTime = 0;
    if(millis() - prevI2cTime >= 100) {
        prevI2cTime = millis();
        if(rw_mode == 0) {
            // WRITE: 마스터 카운터 → 슬레이브로 전송
            I2C_Write(I2C0, counter);
        } else {
            // READ: 슬레이브 카운터 ← 슬레이브에서 수신
            slave_val = I2C_Read(I2C0);
        }
    }

    static upcounter_state_t upCounterState = STOP;
    switch(upCounterState){
    case STOP:
        UpCounter_Stop();
        if(Button_GetState(&hBtnRunStop) == ACT_PUSHED)
            upCounterState = RUN;
        else if(Button_GetState(&hBtnClear) == ACT_PUSHED)
            upCounterState = CLEAR;
        break;
    case RUN:
        UpCounter_Run();
        if(Button_GetState(&hBtnRunStop) == ACT_PUSHED)
            upCounterState = STOP;
        break;
    case CLEAR:
        UpCounter_Clear();
        upCounterState = STOP;
        break;
    default:
        UpCounter_Stop();
        break;
    }
}

void UpCounter_DisLoop(){
    FND_DispDigit();
}

